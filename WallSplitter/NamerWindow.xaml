<Window x:Class="WallSplitter.NamerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NAMER - 이름 일괄 변경"
        Height="680" Width="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="White">
    <!-- 다른 창들과 동일한 이유(Revit 전역 테마 유입 방지)로 색을 명시적으로 고정한다. -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="대상:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
            <RadioButton x:Name="CategoryViewRadio" Content="뷰" GroupName="Category" Margin="0,0,14,0" Checked="CategoryRadio_Checked"/>
            <RadioButton x:Name="CategorySheetRadio" Content="시트" GroupName="Category" Margin="0,0,14,0" Checked="CategoryRadio_Checked"/>
            <RadioButton x:Name="CategoryFamilyRadio" Content="패밀리" GroupName="Category" Margin="0,0,14,0" Checked="CategoryRadio_Checked"/>
            <RadioButton x:Name="CategoryTypeRadio" Content="유형" GroupName="Category" Margin="0,0,14,0" Checked="CategoryRadio_Checked"/>
            <RadioButton x:Name="CategoryLegendRadio" Content="범례" GroupName="Category" Margin="0,0,14,0" Checked="CategoryRadio_Checked"/>
            <RadioButton x:Name="CategoryScheduleRadio" Content="일람표" GroupName="Category" Margin="0,0,14,0" Checked="CategoryRadio_Checked"/>
            <RadioButton x:Name="CategoryMaterialRadio" Content="재료" GroupName="Category" Checked="CategoryRadio_Checked"/>
        </StackPanel>

        <StackPanel x:Name="MaterialDuplicatePanel" Grid.Row="1" Margin="0,0,0,8" Visibility="Collapsed">
            <TextBlock Text="이름이 겹치는 재료가 이미 있으면:" FontWeight="Bold" Margin="0,0,0,4"/>
            <RadioButton x:Name="DuplicateMergeRadio" Content="기존 같은 이름 재료로 병합" GroupName="DuplicateMaterial" IsChecked="True" Margin="0,0,0,4"/>
            <RadioButton x:Name="DuplicateSuffixRadio" Content="뒤에 숫자를 붙여 새 이름으로 저장" GroupName="DuplicateMaterial"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="필터:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="FilterBox" Width="220" VerticalContentAlignment="Center" TextChanged="FilterBox_TextChanged"/>
            <ComboBox x:Name="FilterModeCombo" Width="130" Margin="6,0,0,0" SelectedIndex="0" SelectionChanged="FilterModeCombo_SelectionChanged">
                <ComboBoxItem Content="포함됨"/>
                <ComboBoxItem Content="포함하지 않음"/>
                <ComboBoxItem Content="일치함"/>
                <ComboBoxItem Content="일치하지 않음"/>
                <ComboBoxItem Content="~로 시작하는"/>
                <ComboBoxItem Content="~로 끝나는"/>
            </ComboBox>
            <Button x:Name="SelectAllButton" Content="전체 선택" Margin="14,0,0,0" Click="SelectAllButton_Click"/>
            <Button x:Name="SelectNoneButton" Content="전체 해제" Margin="6,0,0,0" Click="SelectNoneButton_Click"/>
            <TextBlock Text="(목록에서 드래그하면 여러 항목을 한 번에 체크/해제할 수 있습니다)" VerticalAlignment="Center" Foreground="Gray" Margin="14,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="작업:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
            <RadioButton x:Name="ModeReplaceRadio" Content="문자열 치환" GroupName="Mode" IsChecked="True" Margin="0,0,14,0" Checked="ModeRadio_Checked"/>
            <RadioButton x:Name="ModeInsertRadio" Content="위치에 삽입" GroupName="Mode" Margin="0,0,14,0" Checked="ModeRadio_Checked"/>
            <RadioButton x:Name="ModeSwapRadio" Content="구분자 기준 자리바꾸기" GroupName="Mode" Margin="0,0,14,0" Checked="ModeRadio_Checked"/>
            <RadioButton x:Name="ModeDeleteRangeRadio" Content="구간 삭제" GroupName="Mode" Checked="ModeRadio_Checked"/>
        </StackPanel>

        <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,0,8">
            <Grid>
                <StackPanel x:Name="ReplacePanel" Orientation="Horizontal">
                    <TextBlock Text="찾을 문자열:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="FindBox" Width="160" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                    <TextBlock Text="바꿀 문자열:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox x:Name="ReplaceBox" Width="160" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                </StackPanel>

                <StackPanel x:Name="InsertPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="삽입 위치 (앞에서부터 몇 번째, 예: 5):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="PositionBox" Width="60" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                    <TextBlock Text="삽입할 문자열:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox x:Name="InsertTextBox" Width="160" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                </StackPanel>

                <StackPanel x:Name="SwapPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="구분자 문자 (첫 번째로 나오는 위치를 기준으로 앞/뒤를 서로 바꿉니다. 예: '-'):" VerticalAlignment="Center" Margin="0,0,6,0" TextWrapping="Wrap" Width="360"/>
                    <TextBox x:Name="DelimiterBox" Width="60" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                </StackPanel>

                <StackPanel x:Name="DeleteRangePanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="시작 위치 (앞에서부터 몇 번째, 예: 6):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="StartPosBox" Width="60" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                    <TextBlock Text="끝 위치 (예: 9):" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox x:Name="EndPosBox" Width="60" VerticalContentAlignment="Center" TextChanged="Param_TextChanged"/>
                    <TextBlock Text="→ 6,7,8,9번째 문자가 삭제됩니다" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="Gray"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="5" BorderBrush="#CCCCCC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 이름이 길어 "..."으로 잘리는 문제 때문에 추가한 열 너비 조절용 헤더. 아래 목록의 각 행은
                     StackPanel(그리드 아님)이라 자체 열 개념이 없으므로, NameColumnSplitter를 드래그할 때마다
                     코드 비하인드에서 이미 그려진 모든 행의 TextBlock.Width를 이 ColumnDefinition들의
                     ActualWidth로 다시 써서 맞춘다(자세한 이유는 NamerWindow.xaml.cs의 SetupColumnWidthSync 참고). -->
                <Grid Grid.Row="0" Margin="30,4,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="OldNameColumn" Width="300"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition x:Name="NewNameColumn" Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="기존 이름" FontWeight="Bold" Foreground="Gray"/>
                    <GridSplitter x:Name="NameColumnSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#CCCCCC" ResizeBehavior="PreviousAndNext" DragDelta="NameColumnSplitter_DragDelta"/>
                    <TextBlock Grid.Column="2" Text="변경 후 이름" FontWeight="Bold" Foreground="Gray"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ItemsPanel" Margin="4"
                                MouseMove="ItemsPanel_MouseMove"
                                MouseLeftButtonUp="ItemsPanel_MouseLeftButtonUp"
                                LostMouseCapture="ItemsPanel_LostMouseCapture"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="6" Margin="0,6,0,0">
            <TextBlock x:Name="CountText" Foreground="Gray"/>
            <TextBlock x:Name="PendingChangesText" Foreground="#B36B00" FontWeight="SemiBold" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="취소" Padding="18,5" Margin="0,0,8,0" Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="적용 (창 안에서만)" Padding="18,5" Margin="0,0,16,0" Click="ApplyButton_Click"/>
            <Button Content="최종 적용 (모델에 반영)" Padding="18,5" Click="FinalApplyButton_Click" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
