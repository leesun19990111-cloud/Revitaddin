<Window x:Class="WallSplitter.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WallSplitter 이름 설정"
        Height="640" Width="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="White">
    <!-- Revit이 다크 테마일 때 전역 스타일이 이 창까지 새어 들어와 글자가 배경색과 같아져
         버튼 안 화살표/텍스트가 안 보이는 문제가 있었다. 색을 명시적으로 고정해 테마와 무관하게 항상 보이도록 한다. -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="ModeTabControl" Grid.Row="0" Background="White">
            <TabItem Header="이름 형식으로 생성">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="벽체/바닥 분리 시 생성되는 단일 유형의 이름을 구성하는 매개변수입니다. 순서를 바꾸거나 추가/삭제할 수 있고, 각 매개변수 뒤에 붙는 구분자를 지정할 수 있습니다. &#10;재료명/두께는 분리 대상 복합 벽/바닥에서 자동으로 읽어오므로 값을 직접 입력할 수 없습니다."/>

                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TokenListPanel" Margin="4"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="매개변수 추가:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="AddKindCombo" Width="140" SelectedIndex="0"/>
                        <Button x:Name="AddButton" Content="+ 추가" Margin="8,0,0,0" Padding="10,3" Click="AddButton_Click"/>
                        <Button x:Name="ResetButton" Content="기본값으로 재설정" Margin="16,0,0,0" Padding="10,3" Click="ResetButton_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <TextBlock Text="미리보기 (재질명=샘플재질, 두께=50mm 가정)" FontWeight="Bold"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,6,0,0" Padding="8">
                            <TextBlock x:Name="PreviewText" FontFamily="Consolas" FontSize="14"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="유형 직접 지정">
                <StackPanel Margin="12">
                    <TextBlock TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,0,8"
                               Text="이 모드에서는 이름/유형을 자동으로 만들지 않습니다."/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="벽체/바닥 분리를 실행하면 레이어마다 이미 문서에 있는 유형을 검색해서 직접 선택하는 창이 뜨고, 그 유형이 새 단일 벽/바닥에 그대로 적용됩니다."/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="지정한 유형을 다음 벽/바닥에도 이어서 적용할지는 리본의 '벽체 분리' 패널, '설정' 버튼 아래에 있는 '단일/복수' 버튼으로 전환합니다 (벽체 분리와 바닥 분리가 이 설정을 함께 씁니다)."/>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray" FontStyle="Italic"
                               Text="'복수' 상태에서는 레이어 개수·재료·두께가 직전 지정과 완전히 같은 벽/바닥에만 자동으로 재적용되고, 다르면 사유와 함께 다시 지정 창이 뜹니다."/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Padding="18,5" Margin="0,0,8,0" Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="저장" Padding="18,5" Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
