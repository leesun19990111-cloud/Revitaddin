<Window x:Class="WallSplitter.LayerTypeAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="레이어별 유형 지정"
        Height="480" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="White">
    <!-- SettingsWindow와 같은 이유로 색을 명시적으로 고정 (Revit 다크 테마 전역 스타일이 새어 들어오는 문제 방지) -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBlock x:Name="WarningText" Grid.Row="1" TextWrapping="Wrap" Foreground="Red" FontWeight="Bold"
                   Margin="0,0,0,10" Visibility="Collapsed"/>

        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="RowsPanel" Margin="4"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="취소" Padding="18,5" Margin="0,0,8,0" Click="CancelButton_Click" IsCancel="True"/>
            <Button x:Name="OkButton" Content="확인" Padding="18,5" Click="OkButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
